{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Apprenticeship Ecosystem Submission",
  "type": "object",
  "required": [
    "bundle_id",
    "title",
    "task_status",
    "run_status",
    "created_at"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "task_status": {
      "type": "string"
    },
    "run_status": {
      "type": "string"
    },
    "apprentice_agent": {
      "type": [
        "string",
        "null"
      ]
    },
    "mentor_mode": {
      "type": [
        "string",
        "null"
      ]
    },
    "mentor_model_provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subdomains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attempts": {
      "type": [
        "integer",
        "null"
      ]
    },
    "traced_steps": {
      "type": [
        "integer",
        "null"
      ]
    },
    "artifact_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "package_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "package_hash": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
