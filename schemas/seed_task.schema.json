{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Apprenticeship Seed Task",
  "type": "object",
  "required": [
    "bundle_id",
    "title",
    "task_status",
    "run_status"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "seed_task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "task_status": {
      "type": "string"
    },
    "run_status": {
      "type": "string"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subdomains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trace_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "attempt_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "learning_signals_path": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
